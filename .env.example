# ── Database ──────────────────────────────────────────────────────────────────
# Para rodar LOCALMENTE (sem Docker), use localhost:
DATABASE_URL=postgresql://notifications_user:change-me-strong-password@localhost:5432/notifications_db

# Para rodar com DOCKER COMPOSE, use o nome do servico "db":
# DATABASE_URL=postgresql://notifications_user:change-me-strong-password@db:5432/notifications_db

# Variaveis usadas pelo container PostgreSQL no Docker Compose
POSTGRES_USER=notifications_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=notifications_db

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use um App Password, NAO a sua senha real do Gmail.
# Passos: Conta Google > Seguranca > Verificacao em 2 etapas > Senhas de app
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=seu_email@gmail.com
EMAIL_FROM_NAME=Notification System

# ── Autenticacao ──────────────────────────────────────────────────────────────
# Chave obrigatoria em producao. Gere com:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Passe no header X-API-Key de cada request.
# Deixe vazio em desenvolvimento para desabilitar autenticacao.
API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# Em producao: APP_ENV=production e SECRET_KEY com pelo menos 32 chars aleatorios.
APP_ENV=development
SECRET_KEY=dev-secret-key
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# Em desenvolvimento use *.
# Em producao liste as origens separadas por virgula (CORS * e BLOQUEADO em producao):
# ALLOWED_ORIGINS=https://app.exemplo.com,https://admin.app.exemplo.com
ALLOWED_ORIGINS=*

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_RETRY_INTERVAL_SECONDS=60
SCHEDULER_MAX_RETRIES=3
SCHEDULER_STALE_SENDING_SECONDS=300

